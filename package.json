{
  "name": "obsidian-ai-rag-plugin",
  "version": "1.0.0",
  "description": "Advanced RAG assistant with a persistent LLM-maintained wiki layer for compounding knowledge",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src/**/*.ts manifest.json --max-warnings=0",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "typecheck": "tsc -noEmit -skipLibCheck"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "rag",
    "ai",
    "search",
    "knowledge-base"
  ],
  "author": "Yep",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "builtin-modules": "3.3.0",
    "esbuild": "0.17.3",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.2.4",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.0"
  }
}
